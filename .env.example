APP_NAME=DigiAI Finance API
APP_ENV=development
SECRET_KEY=troque-essa-chave-em-producao
DATABASE_URL=sqlite:///./notafacil.db
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000,https://digiai-finance-beta.onrender.com
DEBUG_RESET_CODE=true

# SMTP opcional para recuperacao de senha real
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Assistente opcional com provedor configuravel
# Opcoes de provider: gemini | openrouter | openai | local
ASSISTANT_PROVIDER=gemini
ASSISTANT_API_KEY=
ASSISTANT_MODEL=gemini-2.5-flash
ASSISTANT_FALLBACK_MODELS=meta-llama/llama-3.2-3b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free
ASSISTANT_SITE_URL=https://digiai-finance-beta.onrender.com
ASSISTANT_APP_TITLE=DiGiaI Caixa
